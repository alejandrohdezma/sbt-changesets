# Initialize git repo and create initial commit with all files
$ exec git init
$ exec git config user.email "test@test.com"
$ exec git config user.name "Test"
$ exec git add .
$ exec git commit --no-gpg-sign -m "Initial commit"

# Simulate a version bump on module-a and module-b (but not module-c)
$ copy-file changes/module-a-version modules/module-a/VERSION
$ copy-file changes/module-b-version modules/module-b/VERSION
$ exec git add .
$ exec git commit --no-gpg-sign -m "Bump versions"

# Run the command
> generatePublishMarkers

# Verify .publish markers were created for changed modules
$ exists modules/module-a/.publish
$ exists modules/module-b/.publish

# Verify .publish marker was NOT created for unchanged module
-$ exists modules/module-c/.publish
